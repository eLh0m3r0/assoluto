# Reverse proxy terminating TLS in front of the FastAPI app.
#
# Copy to /etc/nginx/conf.d/default.conf inside the nginx container
# (docker-compose.prod.yml mounts ./docker/nginx.conf at that path)
# and customise hostnames + certificate paths before starting.

# ---------------------------------------------------------------------
# Rate limit zones
# ---------------------------------------------------------------------
limit_req_zone $binary_remote_addr zone=auth:10m rate=10r/m;
limit_req_zone $binary_remote_addr zone=general:10m rate=60r/s;

# ---------------------------------------------------------------------
# HTTP -> HTTPS redirect
# ---------------------------------------------------------------------
server {
    listen 80;
    server_name assoluto.eu *.assoluto.eu;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    location / {
        return 301 https://$host$request_uri;
    }
}

# ---------------------------------------------------------------------
# Main TLS vhost — matches the wildcard so every tenant subdomain
# (4mex.assoluto.eu, ...) terminates here and proxies to `web`.
# ---------------------------------------------------------------------
server {
    listen 443 ssl http2;
    server_name assoluto.eu *.assoluto.eu;

    ssl_certificate /etc/nginx/certs/fullchain.pem;
    ssl_certificate_key /etc/nginx/certs/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1h;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy same-origin always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    client_max_body_size 60M;  # MAX_UPLOAD_SIZE_MB + a bit of slack

    # Tighter limit on auth endpoints to slow password spraying.
    location = /auth/login {
        limit_req zone=auth burst=5 nodelay;
        proxy_pass http://web:8000;
        include /etc/nginx/conf.d/common-proxy.inc;
    }
    location = /auth/password-reset {
        limit_req zone=auth burst=5 nodelay;
        proxy_pass http://web:8000;
        include /etc/nginx/conf.d/common-proxy.inc;
    }

    # Everything else
    location / {
        limit_req zone=general burst=40 nodelay;
        proxy_pass http://web:8000;
        include /etc/nginx/conf.d/common-proxy.inc;
    }
}

# ---------------------------------------------------------------------
# Shared proxy settings — included from every location to avoid
# repeating headers. Save this as /etc/nginx/conf.d/common-proxy.inc.
# ---------------------------------------------------------------------
# proxy_set_header Host $host;
# proxy_set_header X-Real-IP $remote_addr;
# proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
# proxy_set_header X-Forwarded-Proto $scheme;
# proxy_read_timeout 60s;
# proxy_connect_timeout 5s;
