# =============================================================================
# SME Client Portal - environment variables
# Copy to `.env` for local development.
# =============================================================================

# --- App ---
APP_ENV=development           # development | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000

# --- Database ---
# Async DSN used by the app at runtime
DATABASE_URL=postgresql+asyncpg://portal:portal@localhost:5432/portal
# Sync DSN used by Alembic migrations
DATABASE_SYNC_URL=postgresql+psycopg://portal:portal@localhost:5432/portal

# --- Tenancy ---
# Fallback tenant slug for single-tenant / self-host deployments
# (leave empty when running multi-tenant via subdomains)
DEFAULT_TENANT_SLUG=

# --- S3 / MinIO ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=portal
S3_SECRET_KEY=portalportal
S3_BUCKET=portal
S3_REGION=eu-central-1
S3_USE_SSL=false
S3_PUBLIC_URL=http://localhost:9000/portal

# --- SMTP ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="SME Portal <noreply@localhost>"
SMTP_STARTTLS=false

# --- File uploads ---
MAX_UPLOAD_SIZE_MB=50

# --- Logging ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                # true = JSON lines, false = dev console
