# =============================================================================
# Assoluto - environment variables
# Copy to `.env` for local development.
# =============================================================================

# --- App ---
APP_ENV=development           # development | production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000

# --- Database ---
# Async DSN used by the running app (portal_app: non-owner, subject to RLS).
DATABASE_URL=postgresql+asyncpg://portal_app:portal_app@localhost:5432/portal
# Sync DSN used by Alembic migrations and bootstrap scripts (portal: table
# owner, bypasses RLS).
DATABASE_SYNC_URL=postgresql+psycopg://portal:portal@localhost:5432/portal
# Async owner DSN used by background jobs and CLI scripts that legitimately
# need to work across tenants (scheduled cleanups, scripts/create_tenant.py).
DATABASE_OWNER_URL=postgresql+asyncpg://portal:portal@localhost:5432/portal

# --- Tenancy ---
# Fallback tenant slug for single-tenant / self-host deployments
# (leave empty when running multi-tenant via subdomains)
DEFAULT_TENANT_SLUG=

# --- Localization (i18n) ---
# Default UI language when no cookie / Accept-Language matches.
DEFAULT_LOCALE=cs
# Comma-separated list of supported locale codes shipped with the app.
SUPPORTED_LOCALES=cs,en

# --- Platform operator (legal identity on the ToS / Privacy pages) ---
# When any of these are empty the legal pages (/terms, /privacy) return
# 404 — we never publish a half-filled template a user could legally
# accept against an unnamed party.
PLATFORM_OPERATOR_NAME=
PLATFORM_OPERATOR_ICO=
PLATFORM_OPERATOR_ADDRESS=
PLATFORM_OPERATOR_EMAIL=opensource@assoluto.eu

# --- Billing (Stripe) ---
# Leave all empty to run in "demo mode" — billing UI works but no API
# calls go to Stripe. Set STRIPE_SECRET_KEY + the price IDs to enable
# real payments.
#
# Plan LIMITS (max_users, max_contacts, …) and MARKETING COPY
# (pricing page) are owned by the DB / templates — the migration
# seeds default values. Changing them is a migration or admin-SQL
# job, not an env flip.
#
# The two STRIPE_PRICE_* below are the ONE runtime-tunable bit:
# Stripe price IDs rotate per environment (test-mode vs live mode
# use different IDs). On every boot the app UPSERTs these into
# ``platform_plans.stripe_price_id`` so ``create_checkout_session``
# has a price to hand to Stripe. An empty value leaves the existing
# DB value untouched (useful for staging).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# --- Platform (hosted SaaS layer) ---
# Enable the opt-in app/platform/ package with global Identity,
# cross-tenant login, and platform admin tenant CRUD.
# Keep false for self-hosted / open-source single-tenant deployments.
FEATURE_PLATFORM=false
# Parent domain for the cross-subdomain platform session cookie.
# E.g. ".portal.example.com". Leave empty for single-host dev.
PLATFORM_COOKIE_DOMAIN=
# Staging escape hatch: allow FEATURE_PLATFORM=true in APP_ENV=production
# even without STRIPE_SECRET_KEY. Billing checkout stays in demo mode
# (flips the local Subscription row without charging). DO NOT use on a
# real paying-customer deployment.
FEATURE_PLATFORM_ALLOW_DEMO=false

# --- S3 / MinIO ---
# Internal endpoint used by the app process to talk to S3.
S3_ENDPOINT_URL=http://localhost:9000
# Public endpoint baked into presigned URLs returned to the browser.
# Leave empty to reuse S3_ENDPOINT_URL; in docker-compose set it to the
# host-exposed port (e.g. http://localhost:9000) so the download link
# actually resolves from outside the docker network.
S3_PUBLIC_ENDPOINT_URL=
S3_ACCESS_KEY=portal
S3_SECRET_KEY=portalportal
S3_BUCKET=portal
S3_REGION=eu-central-1
S3_USE_SSL=false

# --- SMTP ---
# Local dev uses Mailpit (port 1025, no auth, no TLS). For production,
# pick the right combo for your provider:
#
#   Brevo (STARTTLS):      SMTP_PORT=587  SMTP_STARTTLS=true
#   Brevo (TLS, legacy):   SMTP_PORT=465  SMTP_STARTTLS=false
#   Gmail / M365 STARTTLS: SMTP_PORT=587  SMTP_STARTTLS=true
#
# If SMTP_USER is set the sender will LOGIN — which requires STARTTLS
# on port 587 or TLS-at-connect on port 465. Port 1025 with real
# credentials = outbound mail will silently time out.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Assoluto <noreply@localhost>"
SMTP_STARTTLS=false

# --- File uploads ---
MAX_UPLOAD_SIZE_MB=50

# --- Rate limiting ---
# Comma-separated CIDR / IP allowlist of upstream proxies whose
# ``X-Forwarded-For`` header we trust. MUST be set in production — if
# empty, slowapi ends up rate-limiting on the reverse proxy's internal
# IP (i.e. a single global bucket for every external client). The
# typical docker-compose + Caddy deploy should trust the RFC1918
# ranges the container bridge uses:
#
#   TRUSTED_PROXIES=172.16.0.0/12,10.0.0.0/8
#
# If Cloudflare is in front, append its published IPv4 + IPv6 ranges.
# Leave empty in local dev (uses the direct peer IP).
TRUSTED_PROXIES=

# --- Logging ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                # true = JSON lines, false = dev console
