# Tailwind build artifacts (app.css itself is committed as a stub so that
# url_for('static', path='css/app.css') works before the build runs; it gets
# overwritten locally and in Docker builds).
app/static/css/app.css.map

# Alembic
# (keep migrations/versions/, just ignore caches)

# Docker volumes (if ever written locally)
docker/volumes/

# Logs
*.log
logs/

# uv
# Note: uv.lock IS checked in for reproducible builds. Only the venv is ignored.
.venv/
# .claude is ignored EXCEPT the project-scoped audit pipeline
# (slash commands + agent definitions) — those ARE checked in so
# the same audit can be re-run by anyone with the repo.
# Worktrees, settings, history remain user-local.
.claude/*
!.claude/commands/
!.claude/agents/
ultraplan.md
bin/
