#: app/templates/www/privacy.html:104
msgid ""
"Billing records (invoices, subscription history) — 10 years from the end "
"of the accounting period, as required by Czech Act 563/1991 Coll. on "
"accounting."
msgstr ""
"Fakturační záznamy (faktury, historie předplatného) — 10 let od konce "
"účetního období, podle zákona č. 563/1991 Sb. o účetnictví."

#: app/templates/www/privacy.html:105
msgid "Request / error logs — 14 days."
msgstr "Logy požadavků / chyb — 14 dní."

#: app/templates/www/privacy.html:106
msgid "Database backups — 14 days rolling."
msgstr "Zálohy databáze — 14 dní rotace."

